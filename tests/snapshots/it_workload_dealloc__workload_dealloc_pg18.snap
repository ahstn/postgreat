---
source: tests/it_workload_dealloc.rs
expression: workload_dealloc_snapshot_view(&json)
---
{
  "metadata": {
    "data_source": "pg_stat_statements",
    "entry_deallocations_state": "nonzero",
    "query_text_visible": true,
    "scope": "cumulative_since_reset",
    "stats_reset_state": "available"
  },
  "slow_query_kinds": [
    "mean_time",
    "shared_blks_read",
    "temp_blks_written",
    "total_time"
  ],
  "warning_categories": [
    "deallocations",
    "recent_reset"
  ]
}
